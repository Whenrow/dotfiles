alias gco='git branch | fzf | xargs git checkout'
alias git-fixup='git log --oneline -n 100 | fzf | cut -d " " -f 1 | xargs git commit --no-verify --fixup'
alias ddb="psql -lt | awk '{print $1}' | fzf | xargs dropdb"
alias gfom='git fetch origin master'
alias grh='git reset HEAD^'
alias cal='ncal -3bMw'
alias gti='git'
alias taks='task'
